# Render backend environment variables
# Paste these into Render Dashboard > Service > Environment.

ENVIRONMENT=production

# Supabase Postgres.
# Runtime app: use Supabase Transaction Pooler and asyncpg.
# Example: postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Upstash Redis is recommended for production token/session helpers.
REDIS_URL=rediss://default:PASSWORD@your-upstash-host.upstash.io:6380

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-64-char-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated HTTPS origins are allowed.
# Example: https://bmod.vercel.app,https://www.yourdomain.com
FRONTEND_ORIGIN=https://your-vercel-app.vercel.app

# Full international number without plus sign.
WHATSAPP_NUMBER=2348012345678

# Resend SMTP.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_your_resend_api_key
EMAIL_FROM=no-reply@yourdomain.com

# Cloudflare R2 image storage.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET_NAME=bmod-images
R2_PUBLIC_URL=https://images.yourdomain.com
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
